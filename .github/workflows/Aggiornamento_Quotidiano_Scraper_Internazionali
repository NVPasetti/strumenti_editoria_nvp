name: Aggiornamento Quotidiano Scraper Internazionali

on:
  schedule:
    # Esegue lo script ogni giorno alle 03:00 UTC (4:00 italiane)
    - cron: '0 3 * * *'
  workflow_dispatch: # Permette anche l'avvio manuale cliccando "Run workflow" su GitHub

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout del codice
      uses: actions/checkout@v3

    - name: Configurazione Python
      uses: actions/setup-python@v4
      with:
        python-version: '3.9'

    - name: Installazione dipendenze
      run: |
        python -m pip install --upgrade pip
        pip install pandas beautifulsoup4 nodriver

    - name: Esecuzione Scraper Internazionali
      run: python scraper_internazionali.py

    - name: Esecuzione Scraper NYT Bestsellers
      run: python scraper_nyt.py

    - name: Esecuzione Scraper Decitre
      run: python scraper_decitre.py

    - name: Commit e Push dei risultati
      run: |
        git config --local user.email "action@github.com"
        git config --local user.name "GitHub Action"
        git add dati_internazionali.csv dati_decitre_scraper.csv
        # Il comando || exit 0 serve a non far fallire l'azione se non ci sono modifiche nei CSV
        git commit -m "Aggiornamento automatico dati: $(date +'%Y-%m-%d')" || exit 0
        git push
